# Environment Configuration Example
# Copy this file to .env and update with your values

# CORS Configuration
# For production, specify allowed frontend domains (comma-separated)
# For development, leave commented to use localhost defaults
# ALLOWED_ORIGINS=https://myapp.com,https://www.myapp.com

# Kite API Configuration
# KITE_API_KEY=your_api_key_here
# KITE_API_SECRET=your_api_secret_here

# Trading Mode
# Set to true for paper trading (simulated orders, no real money)
# Set to false for live trading (real orders with real money)
# PAPER_TRADING=true
